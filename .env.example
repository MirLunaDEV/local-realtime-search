LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
DOCKER_LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=your-loaded-lm-studio-model-id
LOCAL_TIMEZONE=Asia/Seoul

CACHE_PATH=.cache/local-realtime-search.sqlite3
FETCHER=auto
ALLOW_PRIVATE_NETWORK_FETCH=false
RESOLVE_FETCH_HOSTNAMES=true
SEARCH_CACHE_TTL_SECONDS=900
PAGE_CACHE_TTL_SECONDS=86400
LM_STUDIO_MAX_TOKENS=4096
LM_STUDIO_FINALIZER_MAX_TOKENS=2048
LM_STUDIO_RETRY_ON_EMPTY_CONTENT=true

SEARXNG_BASE_URL=http://127.0.0.1:8080

SEARCH_TIMEOUT_SECONDS=2.5
WEATHER_TIMEOUT_SECONDS=2.5
FETCH_TIMEOUT_SECONDS=3.0
CRAWL4AI_TIMEOUT_SECONDS=8.0
SYNTHESIS_TIMEOUT_SECONDS=180.0
MAX_QUERY_VARIANTS=6
MAX_CANDIDATE_URLS=24
MAX_FETCH_URLS=16
MAX_EVIDENCE_CHUNKS=20
MAX_EVIDENCE_CHARS=24000
